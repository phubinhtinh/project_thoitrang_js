{
	"info": {
		"name": "Shop Thoi Trang - Test APIs",
		"description": "Toàn bộ API test cho Shop Thời Trang",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Xác thực (Auth)",
			"item": [
				{
					"name": "1. Đăng ký tài khoản",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"email\": \"test@gmail.com\",\n  \"password\": \"password123\",\n  \"phone\": \"0901234567\"\n}"
						},
						"url": "{{baseUrl}}/auth/register"
					}
				},
				{
					"name": "2. Đăng nhập",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": "{{baseUrl}}/auth/login"
					}
				},
				{
					"name": "3. Lấy thông tin tài khoản [CẦN TOKEN]",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": "{{baseUrl}}/auth/profile"
					}
				}
			]
		},
		{
