						"body": {
							"mode": "raw",
							"raw": "{\n  \"paymentMethod\": \"cod\",\n  \"shippingAddress\": \"123 Đường Số 1, Quận 10, TPHCM\",\n  \"phoneReceiver\": \"0988111222\"\n}"
